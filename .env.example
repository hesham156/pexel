NEXTAUTH_SECRET="your-super-secret-key-change-in-production-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Optional: upload storage
UPLOAD_DIR="./public/uploads"

# تكامل منصة "حياك" (Hayyak) — متجر مبرمَج خاص
# مفتاح التوقيع يظهر مرة واحدة فقط في لوحة حياك (التكاملات → متجر مبرمَج خاص).
# لا تُشارك هذا المفتاح ولا ترفعه إلى Git — ضعه في .env أو متغيرات بيئة Vercel.
HAYYAK_SIGNING_SECRET="whsec_..."
HAYYAK_STORE_ID="pexelco"
HAYYAK_BASE_URL="https://7ayak.app"
